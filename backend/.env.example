# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finanzplus_austria
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration - RESEND (Recommandé)
# Pour obtenir votre clé API: https://resend.com/api-keys
# IMPORTANT: EMAIL_FROM doit être une adresse de votre domaine vérifié sur Resend
RESEND_API_KEY=re_123456789_your_resend_api_key_here
EMAIL_FROM=noreply@finanzplus.xyz
ADMIN_EMAIL=admin@finanzplus.xyz

# Email Configuration (SMTP) - Alternative (non utilisé si RESEND configuré)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# WhatsApp Configuration
WHATSAPP_PHONE=+43123456789

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Calendly Configuration
CALENDLY_URL=https://calendly.com/finanzplus-austria

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_change_this_in_production
SESSION_COOKIE_MAX_AGE=86400000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Payment Gateway (Optional - for future implementation)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Sentry Error Tracking (Optional)
SENTRY_DSN=your_sentry_dsn_here

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS S3 Configuration (Optional - for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-central-1
AWS_S3_BUCKET=finanzplus-documents

# Twilio SMS Configuration (Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+43123456789

# Company Information
COMPANY_NAME=FinanzPlus Austria GmbH
COMPANY_ADDRESS=Hauptstraße 123, 1010 Wien, Österreich
COMPANY_PHONE=+43 123 456 789
COMPANY_EMAIL=kontakt@finanzplus.at
COMPANY_WEBSITE=https://www.finanzplus.at

# Business Hours
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_DAYS=1,2,3,4,5

# Loan Configuration
MIN_LOAN_AMOUNT=1000
MAX_LOAN_AMOUNT=500000
MIN_LOAN_DURATION=12
MAX_LOAN_DURATION=360
DEFAULT_INTEREST_RATE=3.5

# Credit Score Thresholds
CREDIT_SCORE_EXCELLENT=750
CREDIT_SCORE_GOOD=650
CREDIT_SCORE_FAIR=550
CREDIT_SCORE_POOR=450

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Feature Flags
FEATURE_LOAN_COMPARATOR=true
FEATURE_CREDIT_SCORE=true
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_VIDEO_CALL=true
FEATURE_CHAT_SUPPORT=false

# API Rate Limiting
API_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT_MAX=100

# Cache Configuration
CACHE_TTL=3600
CACHE_ENABLED=true

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Wir führen gerade Wartungsarbeiten durch. Bitte versuchen Sie es später erneut.
# Google reCAPTCHA v3
# Pour obtenir vos clés: https://www.google.com/recaptcha/admin
# Clés de test (à remplacer en production):
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_MIN_SCORE=0.5
